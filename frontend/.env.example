# ── Database (Neon PostgreSQL — free tier) ────────────────────────────────────
# Get from: https://neon.tech → New Project → Connection string
# Use the "pooled" connection string here:
DATABASE_URL="postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require"
# Use the "direct" connection string here (for migrations):
DIRECT_URL="postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-random-secret-here"

# Google OAuth — from https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs must include:
#   http://localhost:3000/api/auth/callback/google  (local)
#   https://your-app.vercel.app/api/auth/callback/google  (production)
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# ── Gemini (free tier) ────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY="AIza..."
GEMINI_MODEL="gemini-2.0-flash"
