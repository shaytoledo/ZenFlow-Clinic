# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./promptbase.db

# ── Optimizer engine ──────────────────────────────────────────────────────────
# "gemini"    → uses Google Generative AI (free tier available)
# "anthropic" → uses Claude (paid)
OPTIMIZER_ENGINE=gemini

# ── Google Generative AI (free tier) ─────────────────────────────────────────
# Get your free key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIza...

# Which Gemini model to use:
#   gemini-2.0-flash   — fastest, free tier  ✓ (recommended)
#   gemini-1.5-flash   — also free tier      ✓
#   gemini-1.5-pro     — higher quality, free with limits
GEMINI_MODEL=gemini-2.0-flash

# ── Anthropic / Claude (optional, only needed if OPTIMIZER_ENGINE=anthropic) ──
# ANTHROPIC_API_KEY=sk-ant-...
